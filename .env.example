# ===========================================
# PAINEL CCO - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commit o arquivo .env com dados sensíveis

# -------------------------------------------
# Microsoft Azure AD (Autenticação)
# -------------------------------------------
VITE_AZURE_CLIENT_ID=seu_client_id_aqui
VITE_AZURE_TENANT_ID=seu_tenant_id_aqui
VITE_AZURE_SCOPES=User.Read,Sites.ReadWrite.All

# -------------------------------------------
# Microsoft Azure AD (Viewer - 2º App Registration)
# -------------------------------------------
VITE_AZURE_VIEWER_CLIENT_ID=
VITE_AZURE_VIEWER_TENANT_ID=
VITE_AZURE_VIEWER_SCOPES=User.Read,Sites.ReadWrite.All
VITE_AZURE_VIEWER_AUTHORITY=

# -------------------------------------------
# SharePoint Online
# -------------------------------------------
VITE_SHAREPOINT_SITE_PATH=vialacteoscombr.sharepoint.com:/sites/CCO

# -------------------------------------------
# Azure AD - Client Secret para app-only auth (server-side)
# -------------------------------------------
VITE_AZURE_CLIENT_SECRET=seu_client_secret_aqui

# -------------------------------------------
# PostgreSQL - Route Web (server-side)
# -------------------------------------------
RWE_DB_URL=postgresql://usuario:senha@host:5432/conexao_route_web
RWE_DB_SSL=false
RWE_DB_SCHEMA=public

# -------------------------------------------
# PostgreSQL - Eventos de Manutenção (server-side)
# -------------------------------------------
# Use SEM prefixo VITE_ para manter segredo no backend (Vercel Functions)
MAINT_DB_URL=postgresql://usuario:senha@host:5432/appdb
MAINT_DB_SSL=true
MAINT_DB_SCHEMA=public
MAINT_DB_TABLE=manutencoes

# -------------------------------------------
# PostgreSQL - Rotas Pendentes (server-side)
# -------------------------------------------
ROTAS_PEND_DB_URL=postgresql://usuario:senha@host:5432/apbd
ROTAS_PEND_DB_SSL=true
ROTAS_PEND_DB_SCHEMA=faturamento
ROTAS_PEND_DB_TABLE=Rota

# -------------------------------------------
# PostgreSQL - Última Coleta (server-side)
# -------------------------------------------
UC_DB_URL=postgresql://usuario:senha@host:5432/checklist_web
UC_DB_SSL=true
UC_DB_SCHEMA=checklist_web

# -------------------------------------------
# PostgreSQL - CCO Painel (server-side)
# Saídas de rotas, não coletas e config operação
# -------------------------------------------
CCO_DB_URL=postgresql://usuario:senha@host:5432/checklist_web
CCO_DB_SSL=true
CCO_DB_SCHEMA=public

# -------------------------------------------
# Servidor de Desenvolvimento
# -------------------------------------------
VITE_SERVER_PORT=3001

# -------------------------------------------
# Segurança - Limitação de Login
# -------------------------------------------
LIMITAR_RETRY_LOGIN=5
LOGIN_LOCKOUT_MINUTES=15

# -------------------------------------------
# Cloudflare Turnstile (Proteção Anti-Bot)
# -------------------------------------------
SITE_KEY=sua_turnstile_site_key_aqui
